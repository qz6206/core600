# 复制此文件为 .env.local 并填入真实 key
FMP_API_KEY=
POLYGON_API_KEY=
SILICONFLOW_API_KEY=
# EDGAR fair-access policy 要求真邮箱
EDGAR_USER_AGENT=YourName your@email.com

# === AskAI (AI 问答功能, 可选) ===
# Upstash Redis 用于 rate limit (单 IP 3/min, 20/day; 全站 1000/day)
# 1) 注册 https://upstash.com/ 免费账号
# 2) Console → Redis → Create Database (选 Global, 免费 256MB / 10K commands/day)
# 3) 复制 REST URL + REST Token 填这里
# 没设置时 AskAI 会跳过限流, 本地开发可以但生产环境必填
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
